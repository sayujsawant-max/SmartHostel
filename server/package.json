{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch -r tsconfig-paths/register src/index.ts",
    "dev:worker": "tsx watch -r tsconfig-paths/register src/worker/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "seed": "tsx -r tsconfig-paths/register src/scripts/seed.ts",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint ."
  },
  "dependencies": {
    "bcryptjs": "3.0.3",
    "cloudinary": "2.9.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "dotenv": "17.3.1",
    "express": "5.2.1",
    "express-rate-limit": "8.2.1",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.3",
    "mongoose": "9.2.4",
    "multer": "2.1.0",
    "node-cron": "4.2.1",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "uuid": "13.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@types/bcryptjs": "2.4.6",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/multer": "2.0.0",
    "@types/node": "24.11.0",
    "@types/supertest": "7.2.0",
    "@types/uuid": "10.0.0",
    "eslint": "9.39.3",
    "globals": "16.5.0",
    "mongodb-memory-server": "11.0.1",
    "pino-pretty": "13.1.3",
    "supertest": "7.2.2",
    "tsc-alias": "1.8.16",
    "tsconfig-paths": "4.2.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.0.18"
  }
}
