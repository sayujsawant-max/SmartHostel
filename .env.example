# Server
NODE_ENV=development
PORT=5000

# Database — use localhost for local dev, mongo for Docker
MONGODB_URI=mongodb://localhost:27017/smarthostel

# Secrets — CHANGE THESE in production (min 32 chars each)
JWT_SECRET=change-me-to-at-least-32-characters!!
QR_SECRET=change-me-to-at-least-32-characters!!

# Auth tuning
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION_MS=15m
ACCESS_TOKEN_EXPIRY=4h
REFRESH_TOKEN_EXPIRY=7d

# CORS — comma-separated origins
# Local dev: http://localhost:5173 (Vite dev server)
# Docker/prod: http://localhost:5000 (same-site, Express serves SPA)
ALLOWED_ORIGINS=http://localhost:5173

# Google OAuth — optional, leave empty to disable Google Sign-In
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@smarthostel.com

# Push Notifications (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@smarthostel.com

# File Upload — optional, for complaint photo uploads
CLOUDINARY_URL=

# Error monitoring (optional — Sentry)
SENTRY_DSN=
VITE_SENTRY_DSN=

# AI (optional)
OPENAI_API_KEY=

# Cron worker — set to true in production (or in docker-compose worker service)
CRON_ENABLED=false

# Docker Compose — MongoDB root credentials
MONGO_ROOT_USERNAME=smarthostel
MONGO_ROOT_PASSWORD=smarthostel_dev
