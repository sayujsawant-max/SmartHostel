NODE_ENV=development
PORT=5000

# Database — use localhost for local dev, mongo for Docker
MONGODB_URI=mongodb://localhost:27017/smarthostel

# Secrets — CHANGE THESE in production (min 32 chars each)
JWT_SECRET=change-me-to-at-least-32-characters!!
QR_SECRET=change-me-to-at-least-32-characters!!

# Cron worker — set to true in production (or in docker-compose worker service)
CRON_ENABLED=false

# Cloudinary — optional, for complaint photo uploads
CLOUDINARY_URL=

# Auth tuning
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION_MS=15m
ACCESS_TOKEN_EXPIRY=4h
REFRESH_TOKEN_EXPIRY=7d

# CORS — comma-separated origins
# Local dev: http://localhost:5173 (Vite dev server)
# Docker/prod: http://localhost:5000 (same-site, Express serves SPA)
ALLOWED_ORIGINS=http://localhost:5173

# Google OAuth — optional, leave empty to disable Google Sign-In
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
